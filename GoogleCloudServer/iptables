curl -s https://www.cloudflare.com/ips-v4 -o /tmp/cf.txt

iptables -t nat -L -n -v --line-numbers #指定nat表 列出规则列表 显示真实IP 列出详细信息 列出编号

iptables -t nat -D OUTPUT -j CF_DNAT #解除自定义链
iptables -t nat -F CF_DNAT #清空自定义链
iptables -t nat -X CF_DNAT #删除自定义链

iptables -t nat -N CF_DNAT #创建自定义链
iptables -t nat -A OUTPUT -j CF_DNAT #引用自定义链
while read ip; do iptables -t nat -A CF_DNAT -d $ip -p tcp -j DNAT --to-destination 64.186.225.82; done < /tmp/cf.txt
